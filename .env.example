# --- LLM providers ---
OPENAI_API_KEY=sk-...

# --- News sources ---
# Optional: NewsAPI.org key. If unset, the RSS feeds are used exclusively.
NEWSAPI_KEY=

# --- Image hosting ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Pexels (stock photos) ---
PEXELS_API_KEY=

# --- Instagram / Meta Graph API ---
IG_USER_ID=
IG_ACCESS_TOKEN=

# --- Telegram approval bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTHORIZED_CHAT_ID=

# --- Behavior ---
# Overall cap per run; the tech/general split must not exceed it.
TOP_STORIES_PER_RUN=3
TECH_STORIES_PER_RUN=2
GENERAL_STORIES_PER_RUN=1
IMAGES_PER_POST=3
NEWSROOM_DB_PATH=state/newsroom.db
